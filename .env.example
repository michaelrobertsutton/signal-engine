# Signal Engine — Environment Variables

# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# Passphrase to access the dashboard
DASHBOARD_PASSPHRASE=change-me

# Secret for signing session cookies
SESSION_SECRET=change-me-to-a-random-string

# Authorization token for cron endpoints (set the same value in Vercel cron config)
CRON_SECRET=change-me

# SAM.gov API key — get a free key at https://api.sam.gov
SAM_GOV_API_KEY=your-sam-gov-api-key

# Set automatically by Vercel for OIDC auth with AI Gateway
# VERCEL_OIDC_TOKEN=auto

# Optional: path to your profile YAML (defaults to config/profile.yaml)
# PROFILE_PATH=config/profile.yaml